{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Nexus AI Assistant",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "ChatHistory": {
      "title": "ChatHistory",
      "description": "Saved chat sessions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "messages", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": "ChatHistory",
      "description": "User chat histories"
    }
  }
}
